lib/config/app_config.dart
lib/config/app_config.local.dart

# Downloaded files
downloads/

# Java server build artifacts
java-server/

# Android key store
android/key.properties
android/local.properties
android/app/release-key.jks

# Environment files
.env
.env.local
.env.*.local

# Google services (if using Firebase)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Any backup signing keys
*.jks
*.keystore
!android/app/upload-keystore.jks.example

